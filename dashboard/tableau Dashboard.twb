            <column-instance column='[Calculation_0575937733509120]' derivation='User' name='[usr:Calculation_0575937733509120:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Order Date]' derivation='Year' name='[yr:Order Date:ok]' pivot='key' type='ordinal' />
