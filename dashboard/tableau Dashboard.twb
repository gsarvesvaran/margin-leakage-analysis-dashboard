    <worksheet name='Discount vs Profit'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#e79dff' fontsize='11'>Discount Impact on Profit Margin</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='sample_superstore' name='federated.1gnlc0i0r1mxni1axld0o0vtx78i' />
          </datasources>
          <datasource-dependencies datasource='federated.1gnlc0i0r1mxni1axld0o0vtx78i'>
            <column caption='Profit Margin' datatype='real' name='[Calculation_0705402764922880]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Profit] )/ SUM([Sales])' />
            </column>
            <column caption='Discount Band' datatype='string' name='[Calculation_0705402765086721]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;&#13;&#10;ELSEIF [Discount] &lt;= 0.1 THEN &quot;0-10%&quot;&#13;&#10;&#13;&#10;ELSEIF [Discount] &lt;= 0.2 THEN &quot;10-20%&quot;&#13;&#10;&#13;&#10;ELSEIF [Discount] &lt;= 0.3 THEN &quot;20-30%&quot;&#13;&#10;&#13;&#10;ELSEIF [Discount] &lt;= 0.4 THEN &quot;30-40%&quot;&#13;&#10;&#13;&#10;ELSE &quot;40%+&quot;&#13;&#10;END' />
            </column>
            <column caption='High Risk Transactions' datatype='string' name='[Calculation_1450873975062529]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Discount] &gt; 0.3&#13;&#10;AND [Profit] &lt; 0&#13;&#10;THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='real' default-format='p0.00%' name='[Discount]' role='measure' type='quantitative' />
