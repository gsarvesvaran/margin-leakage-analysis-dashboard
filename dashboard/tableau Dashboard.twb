          </filter>
          <filter class='categorical' column='[federated.1gnlc0i0r1mxni1axld0o0vtx78i].[Action (Discount Band,Category)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action23_1A455D93EC8F421DAC53F7252B1EA743]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[Calculation_0705402765086721]' />
              <groupfilter function='level-members' level='[Category]' />
