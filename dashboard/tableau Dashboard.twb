        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.1gnlc0i0r1mxni1axld0o0vtx78i].[sum:Calculation_0575937762902017:qk]' />
            </encodings>
            <customized-label>
              <formatted-text>
                <run bold='true' fontalignment='0' fontcolor='#af85f7' fontname='Times New Roman' fontsize='12'>1. Critical Discount Threshold</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Discounts above </run>
                <run bold='true' fontalignment='0' fontcolor='#ff9d9a' fontname='Trebuchet MS'>30%</run>
                <run fontalignment='0' fontname='Trebuchet MS'> consistently produce negative margins.</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run bold='true' fontalignment='0' fontcolor='#f1ce63' fontname='Trebuchet MS'>Recommendation</run>
                <run bold='true' fontalignment='0' fontname='Trebuchet MS'>:</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Require manager approval for discounts above </run>
                <run bold='true' fontalignment='0' fontcolor='#ff9d9a' fontname='Trebuchet MS'>30%</run>
                <run fontalignment='0' fontname='Trebuchet MS'>.</run>
                <run fontalignment='0'>Æ&#10;&#10;</run>
                <run bold='true' fontalignment='0' fontcolor='#af85f7' fontname='Times New Roman' fontsize='12'>2. Regional Margin Leakage</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Central and South regions show high-risk discount concentration.</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run bold='true' fontalignment='0' fontcolor='#f1ce63' fontname='Trebuchet MS'>Recommendation</run>
                <run bold='true' fontalignment='0' fontname='Trebuchet MS'>:</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Implement stricter regional discount controls.</run>
                <run fontalignment='0'>Æ&#10;&#10;</run>
                <run bold='true' fontalignment='0' fontcolor='#af85f7' fontname='Times New Roman' fontsize='12'>3. Category Risk Observation</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Furniture and Tables generate </run>
                <run bold='true' fontalignment='0' fontcolor='#4ba116' fontname='Trebuchet MS'>high</run>
                <run fontalignment='0' fontname='Trebuchet MS'> sales but </run>
                <run bold='true' fontalignment='0' fontcolor='#ff9d9a' fontname='Trebuchet MS'>weak</run>
                <run fontalignment='0' fontname='Trebuchet MS'> margins.</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run bold='true' fontalignment='0' fontcolor='#f1ce63' fontname='Trebuchet MS'>Recommendation</run>
                <run bold='true' fontalignment='0' fontname='Trebuchet MS'>:</run>
                <run fontalignment='0'>Æ&#10;</run>
                <run fontalignment='0' fontname='Trebuchet MS'>Reduce discount exposure in low-margin categories.</run>
              </formatted-text>
            </customized-label>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
